{
  "name": "void-ecosystem",
  "version": "1.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "void-ecosystem",
      "version": "1.0.0",
      "workspaces": [
        "packages/*",
        "apps/*"
      ]
    },
    "apps/auth-service": {
      "name": "@void/auth-service",
      "version": "1.0.0",
      "dependencies": {
        "@void/core-query-builder": "*"
      }
    },
    "node_modules/@void/auth-service": {
      "resolved": "apps/auth-service",
      "link": true
    },
    "node_modules/@void/core-query-builder": {
      "resolved": "packages/core-query-builder",
      "link": true
    },
    "packages/core-query-builder": {
      "name": "@void/core-query-builder",
      "version": "1.0.0"
    }
  }
}
